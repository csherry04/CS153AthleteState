{
  "data_path": "data/processed/daily_features_with_fit.csv",
  "target_column": "readiness_score",
  "date_column": "date",
  "window_days": 28,
  "split": {
    "train_fraction": 0.7,
    "validation_fraction": 0.15,
    "test_fraction": 0.15
  },
  "features": [
    "activity_count",
    "activity_duration_seconds",
    "activity_moving_duration_seconds",
    "activity_distance_m",
    "activity_calories",
    "activity_avg_hr",
    "activity_max_hr",
    "activity_training_load",
    "activity_steps",
    "fitness_vo2MaxValue",
    "load_dailyTrainingLoadAcute",
    "load_dailyTrainingLoadChronic",
    "load_dailyAcuteChronicWorkloadRatio",
    "training_history_weeklyTrainingLoadSum",
    "training_history_loadTunnelMin",
    "training_history_loadTunnelMax",
    "sleep_total_seconds",
    "sleep_total_in_bed_seconds",
    "sleep_nap_seconds",
    "wellness_restingHeartRate",
    "wellness_currentDayRestingHeartRate",
    "wellness_totalSteps",
    "wellness_totalDistanceMeters",
    "wellness_activeKilocalories",
    "wellness_activeSeconds",
    "wellness_highlyActiveSeconds",
    "wellness_moderateIntensityMinutes",
    "wellness_vigorousIntensityMinutes",
    "wellness_minHeartRate",
    "wellness_maxHeartRate",
    "wellness_minAvgHeartRate",
    "wellness_maxAvgHeartRate",
    "wellness_bodyBattery_chargedValue",
    "wellness_bodyBattery_drainedValue",
    "readiness_score",
    "readiness_recoveryTime",
    "readiness_hrvWeeklyAverage",
    "readiness_hrvFactorPercent",
    "readiness_sleepHistoryFactorPercent",
    "readiness_stressHistoryFactorPercent",
    "readiness_acwrFactorPercent",
    "readiness_acuteLoad",
    "endurance_overallScore",
    "hill_overallScore"
  ],
  "plot_columns": [
    "load_dailyTrainingLoadAcute",
    "activity_count",
    "readiness_score",
    "readiness_hrvWeeklyAverage",
    "wellness_restingHeartRate",
    "activity_duration_seconds",
    "activity_distance_m",
    "activity_avg_hr",
    "activity_max_hr"
  ],
  "tcn": {
    "hidden_channels": 32,
    "embedding_dim": 16,
    "kernel_size": 3,
    "dilations": [1, 2, 4],
    "dropout": 0.15,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "batch_size": 32,
    "max_epochs": 300,
    "early_stopping_patience": 30,
    "rolling_anomaly_window": 28
  },
  "masked_pretraining": {
    "mask_fraction": 0.15,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "batch_size": 32,
    "max_epochs": 250,
    "early_stopping_patience": 25
  }
}
